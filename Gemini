        // --- 2. LAYOUT ENGINE ---
        function computeDynamicLayout(activeNodes, activeSpousesMap) {
            if (!activeNodes || activeNodes.length === 0) return { displayNodes: [], displayLines: [] };

            const CARD_W = 240; 
            const SPACING_X = 140;
            const LEVEL_HEIGHT = 200;

            const computedNodes = activeNodes.map(n => ({ ...n, x: 0, y: 0, subtreeWidth: 0, positioned: false }));
            const computedLines = [];

            function isSpouseNodeCheck(node) {
                return node.ancestors.length > 0 && computedNodes.some(p => p.id === node.ancestors[node.ancestors.length - 1] && p.depth === node.depth);
            }

            function getSpouses(mainNodeId) {
                const mainNode = computedNodes.find(n => n.id === mainNodeId);
                if (!mainNode) return [];
                return computedNodes.filter(n => n.ancestors.length > 0 && n.ancestors[n.ancestors.length - 1] === mainNodeId && n.depth === mainNode.depth && n.gender !== mainNode.gender);
            }

            function getChildren(mainNodeId, spouseId) {
                const mainNode = computedNodes.find(n => n.id === mainNodeId);
                if (!mainNode) return [];
                return computedNodes.filter(n => {
                    const isChild = n.ancestors.length > 0 && n.ancestors[n.ancestors.length - 1] === mainNodeId && n.depth === mainNode.depth + 1;
                    if (!isChild) return false;
                    
                    if (n.motherId || n.fatherId) {
                        return n.motherId === spouseId || n.fatherId === spouseId;
                    }
                    return true; 
                });
            }

            function measure(nodeId) {
                const node = computedNodes.find(n => n.id === nodeId);
                if (!node) return 0;
                
                if (isSpouseNodeCheck(node)) return CARD_W;

                const spouses = getSpouses(nodeId);
                
                let activeSpouse = null;
                if (spouses.length > 0) {
                    if (activeSpousesMap[nodeId]) activeSpouse = spouses.find(s => s.id === activeSpousesMap[nodeId]);
                    if (!activeSpouse || getChildren(nodeId, activeSpouse.id).length === 0) {
                        activeSpouse = spouses.find(s => getChildren(nodeId, s.id).length > 0) || spouses[0];
                    }
                }

                let childrenWidth = 0;
                if (activeSpouse) {
                    const children = getChildren(nodeId, activeSpouse.id);
                    children.forEach(c => { childrenWidth += measure(c.id); });
                    if (children.length > 1) childrenWidth += (children.length - 1) * SPACING_X;
                } else {
                    const children = computedNodes.filter(n => n.ancestors.length > 0 && n.ancestors[n.ancestors.length - 1] === nodeId && n.depth === node.depth + 1);
                    children.forEach(c => { childrenWidth += measure(c.id); });
                    if (children.length > 1) childrenWidth += (children.length - 1) * SPACING_X;
                }

                const spousesCount = 1 + spouses.length;
                const selfWidth = spousesCount * CARD_W + (spousesCount - 1) * SPACING_X;
                
                node.subtreeWidth = Math.max(selfWidth, childrenWidth);
                return node.subtreeWidth;
            }

            function position(nodeId, startX, y) {
                const node = computedNodes.find(n => n.id === nodeId);
                if (!node) return;
                node.positioned = true; 

                const spouses = getSpouses(nodeId);
                const centerX = startX + node.subtreeWidth / 2;

                if (spouses.length === 0) {
                    node.x = centerX;
                    node.y = y;
                    const children = computedNodes.filter(n => n.ancestors.length > 0 && n.ancestors[n.ancestors.length - 1] === nodeId && n.depth === node.depth + 1);
                    let totalChildrenWidth = children.reduce((acc, c) => acc + c.subtreeWidth, 0) + Math.max(0, children.length - 1) * SPACING_X;
                    let childCurrentX = centerX - totalChildrenWidth / 2;

                    children.forEach(c => {
                        position(c.id, childCurrentX, y + LEVEL_HEIGHT);
                        childCurrentX += c.subtreeWidth + SPACING_X;
                    });
                    if (children.length > 0) {
                        const dropY = y + LEVEL_HEIGHT / 2;
                        computedLines.push({ id: `d_${node.id}`, x1: node.x, y1: node.y, x2: node.x, y2: dropY, ownerId: node.id });
                        
                        children.forEach(c => { 
                            computedLines.push({ id: `cd_${c.id}`, x1: c.x, y1: dropY, x2: c.x, y2: c.y, ownerId: node.id, isDashed: c.isStepChild }); 
                        });
                        
                        if (children.length > 1) computedLines.push({ id: `f_${node.id}`, x1: children[0].x, y1: dropY, x2: children[children.length-1].x, y2: dropY, ownerId: node.id });
                    }
                    return;
                }

                let activeSpouse = null;
                if (activeSpousesMap[nodeId]) activeSpouse = spouses.find(s => s.id === activeSpousesMap[nodeId]);
                if (!activeSpouse || getChildren(nodeId, activeSpouse.id).length === 0) activeSpouse = spouses.find(s => getChildren(nodeId, s.id).length > 0) || spouses[0];
                
                const orderedSpouses = [activeSpouse, ...spouses.filter(s => s.id !== activeSpouse.id)];
                orderedSpouses.forEach(s => s.isActiveSpouse = (s.id === activeSpouse.id));

                const spousesCount = 1 + spouses.length;
                const selfWidth = spousesCount * CARD_W + (spousesCount - 1) * SPACING_X;
                let currentX = centerX - selfWidth / 2;

                node.x = currentX + CARD_W / 2;
                node.y = y;
                currentX += CARD_W + SPACING_X;

                orderedSpouses.forEach(s => {
                    s.positioned = true;
                    s.x = currentX + CARD_W / 2;
                    s.y = y;
                    currentX += CARD_W + SPACING_X;
                    computedLines.push({ id: `m_${node.id}_${s.id}`, x1: node.x, y1: node.y, x2: s.x, y2: s.y, ownerId: node.id });
                });

                const children = getChildren(nodeId, activeSpouse.id);
                if (children.length > 0) {
                    const dropX = (node.x + activeSpouse.x) / 2;
                    const dropY = y + LEVEL_HEIGHT / 2;

                    computedLines.push({ id: `d_${node.id}_active`, x1: dropX, y1: node.y, x2: dropX, y2: dropY, ownerId: node.id });

                    let totalChildrenWidth = children.reduce((acc, c) => acc + c.subtreeWidth, 0) + Math.max(0, children.length - 1) * SPACING_X;
                    let childCurrentX = dropX - totalChildrenWidth / 2;

                    children.forEach(c => {
                        position(c.id, childCurrentX, y + LEVEL_HEIGHT);
                        childCurrentX += c.subtreeWidth + SPACING_X;
                    });

                    if (children.length > 0) {
                        children.forEach(c => { 
                            computedLines.push({ id: `cd_${c.id}`, x1: c.x, y1: dropY, x2: c.x, y2: c.y, ownerId: node.id, isDashed: c.isStepChild }); 
                        });
                        if (children.length > 1) computedLines.push({ id: `f_${node.id}_active`, x1: children[0].x, y1: dropY, x2: children[children.length-1].x, y2: dropY, ownerId: node.id });
                    }
                }
            }

            const minDepth = computedNodes.length > 0 ? Math.min(...computedNodes.map(n => n.depth)) : 0;
            const roots = computedNodes.filter(n => n.depth === minDepth && !isSpouseNodeCheck(n));
            
            let currentRootX = 0;
            roots.forEach(root => {
                measure(root.id);
                position(root.id, currentRootX, 0);
                currentRootX += root.subtreeWidth + SPACING_X * 2;
            });

            const finalNodes = computedNodes.filter(n => n.positioned);
            const finalLines = computedLines;

            return { displayNodes: finalNodes, displayLines: finalLines };
        }

        // --- MAIN APP COMPONENT ---
