            const [addNodeTarget, setAddNodeTarget] = useState(null);
            const [isAddingRoot, setIsAddingRoot] = useState(false); 
            const [addFormData, setAddFormData] = useState({ name: '', gender: 'M', relation: 'son', dob: '', bio: '', parent2Id: '', bioFatherName: '', status: 'alive' });
            const [isExistingRelative, setIsExistingRelative] = useState(false);
