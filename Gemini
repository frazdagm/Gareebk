                                        <div>
                                            <label className="block text-xs sm:text-sm font-bold text-slate-700 mb-1">{isRTL ? 'نبذة قصيرة' : 'Short Bio'}</label>
                                            <textarea rows="3" value={editFormData.bio} onChange={e => setEditFormData({...editFormData, bio: e.target.value})} className="w-full border border-slate-200 rounded-xl p-2.5 sm:p-3 outline-none resize-none text-sm sm:text-base"></textarea>
                                        </div>
                                        
                                        <div className="pt-2 flex flex-col gap-2">
                                            <button disabled={isSubmitting} type="submit" className="w-full bg-amber-500 text-white font-bold py-3.5 rounded-xl hover:bg-amber-600 transition shadow-md disabled:opacity-50 flex items-center justify-center gap-2">
                                                {isSubmitting && <svg className="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24"><circle className="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" strokeWidth="4"></circle><path className="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>}
                                                {isSubmitting ? (isRTL ? 'جاري الحفظ...' : 'Saving...') : (isRTL ? 'حفظ التعديلات' : 'Save Changes')}
                                            </button>
                                            <button type="button" onClick={handleDeleteNode} className="w-full bg-red-50 border border-red-200 text-red-600 font-bold py-3 rounded-xl hover:bg-red-100 transition shadow-sm mt-1">
                                                {isRTL ? 'حذف هذا الفرد' : 'Delete Member'}
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    )}

                    {/* TUTORIAL MODAL */}
                    {showTutorial && (
                        <div className="fixed inset-0 bg-slate-900/60 z-[100] flex items-center justify-center p-4 backdrop-blur-sm" dir={isRTL ? "rtl" : "ltr"}>
                            <div className="bg-white rounded-3xl shadow-2xl w-full max-w-md overflow-hidden flex flex-col">
                                <div className="p-6 text-center">
                                    <div className="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 mx-auto mb-4">
                                        {tutorialStep === 0 && <svg className="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>}
                                        {tutorialStep === 1 && <svg className="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"></path></svg>}
                                        {tutorialStep === 2 && <svg className="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>}
                                        {tutorialStep === 3 && <svg className="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M12 4v16m8-8H4"></path></svg>}
                                        {tutorialStep === 4 && <svg className="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>}
                                    </div>
                                    <h2 className="text-2xl font-bold text-slate-800 mb-2">
                                        {tutorialStep === 0 && (isRTL ? 'مرحباً بك في قريبك!' : 'Welcome to Gareebk!')}
                                        {tutorialStep === 1 && (isRTL ? 'التنقل في الشجرة' : 'Navigating the Tree')}
                                        {tutorialStep === 2 && (isRTL ? 'وضع التعديل' : 'Edit Mode')}
                                        {tutorialStep === 3 && (isRTL ? 'إضافة الأقارب' : 'Adding Relatives')}
                                        {tutorialStep === 4 && (isRTL ? 'التفاصيل والتركيز' : 'Details & Focus')}
                                    </h2>
                                    <p className="text-slate-600 leading-relaxed h-20 flex items-center justify-center">
                                        {tutorialStep === 0 && (isRTL ? 'لنأخذ جولة سريعة لمعرفة كيف تبني وتستعرض شجرة عائلتك بسهولة.' : 'Let\'s take a quick tour to learn how to build and view your family tree easily.')}
                                        {tutorialStep === 1 && (isRTL ? 'انقر واسحب في أي مكان للتحرك حول الشجرة. استخدم عجلة الماوس أو المس بإصبعين للتقريب والتبعيد.' : 'Click and drag anywhere to move around. Use your mouse wheel or pinch on mobile to zoom in and out.')}
                                        {tutorialStep === 2 && (isRTL ? 'تأكد من تفعيل "وضع التعديل" في الأعلى لتتمكن من إضافة أفراد الشجرة وتعديل بياناتهم.' : 'Make sure "Edit Mode" is active at the top to add tree members and modify their data.')}
                                        {tutorialStep === 3 && (isRTL ? 'عندما يكون وضع التعديل مفعلاً، سترى زر (+) أخضر أسفل كل شخص لإضافة والديه، شركائه، أو أبنائه.' : 'When Edit Mode is on, you will see a green (+) button below each person to add parents, spouses, or children.')}
                                        {tutorialStep === 4 && (isRTL ? 'انقر على بطاقة أي شخص لفتح لوحة التفاصيل. يمكنك من هناك "التركيز" على عائلته الصغيرة فقط.' : 'Click any person\'s card to open their details panel. From there, you can "Focus" to see only their immediate family.')}
                                    </p>
                                </div>
                                <div className="bg-slate-50 p-4 border-t border-slate-100 flex justify-between items-center">
                                    <div className="flex gap-1.5 ml-2 mr-2">
                                        {[0, 1, 2, 3, 4].map(step => (
                                            <div key={step} className={`w-2 h-2 rounded-full transition-all ${tutorialStep === step ? 'bg-blue-600 w-4' : 'bg-slate-300'}`}></div>
                                        ))}
                                    </div>
                                    <div className="flex gap-2">
                                        {tutorialStep < 4 ? (
                                            <>
                                                <button onClick={() => { localStorage.setItem('gareebk_tutorial_seen_v1', 'true'); setShowTutorial(false); }} className="px-4 py-2 text-slate-500 font-bold hover:bg-slate-200 rounded-xl transition">
                                                    {isRTL ? 'تخطي' : 'Skip'}
                                                </button>
                                                <button onClick={() => setTutorialStep(prev => prev + 1)} className="px-6 py-2 bg-blue-600 text-white font-bold rounded-xl shadow-md hover:bg-blue-700 transition">
                                                    {isRTL ? 'التالي' : 'Next'}
                                                </button>
                                            </>
                                        ) : (
                                            <button onClick={() => { localStorage.setItem('gareebk_tutorial_seen_v1', 'true'); setShowTutorial(false); }} className="px-6 py-2 bg-emerald-600 text-white font-bold rounded-xl shadow-md hover:bg-emerald-700 transition">
                                                {isRTL ? 'ابدأ الاستخدام' : 'Get Started'}
                                            </button>
                                        )}
                                    </div>
                                </div>
                            </div>
                        </div>
                    )}
                    
                    {/* CUSTOM CONFIRM DIALOG */}
                    <ConfirmDialog />
                </div>
            );
        };

        const root = createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
