                            return n;
                        });

                        finalNodes.push(newParent);
                        
                        const nodesToSave = [newParent, ...finalNodes.filter(n => n.id === target.id || n.ancestors.includes(target.id))];
                        saveNodesToDB(nodesToSave);
                        setRawNodes(finalNodes);
