            // Camera Engine
            const updateCameraState = (newPan, newScale) => {
                setScale(newScale);
                scaleRef.current = newScale;
                setPan(newPan);
                panRef.current = newPan;
                initialPanRef.current = newPan;
            };

            const centerOnNode = (target, customScale) => {
                if (!target) return;
                const s = customScale || scaleRef.current;
                const screenCenterX = window.innerWidth / 2;
                const screenCenterY = window.innerHeight / 2 - 100;
                const newPan = { x: screenCenterX - (target.x * s), y: screenCenterY - (target.y * s) };
                updateCameraState(newPan, s);
            };

            const getTouchDist = (e) => {
                if (e.touches.length < 2) return 0;
                const dx = e.touches[0].clientX - e.touches[1].clientX;
                const dy = e.touches[0].clientY - e.touches[1].clientY;
                return Math.sqrt(dx * dx + dy * dy);
            };

            const getXY = (e) => {
                const clientX = e.touches ? e.touches[0].clientX : e.clientX;
                const clientY = e.touches ? e.touches[0].clientY : e.clientY;
                return { x: clientX, y: clientY };
            };

            useEffect(() => {
                if (currentView !== 'app') return;

                const handleMove = (e) => {
                    if (e.touches && e.touches.length === 2) {
                        if (pinchStartDistRef.current) {
                            e.preventDefault(); 
                            const newDist = getTouchDist(e);
                            const scaleFactor = newDist / pinchStartDistRef.current;
                            const newScale = Math.min(Math.max(0.05, pinchStartScaleRef.current * scaleFactor), 2.5);
                            updateCameraState(panRef.current, newScale); 
                        }
                        return;
                    }
                    if (!isDraggingRef.current || !dragStartRef.current) return;
                    e.preventDefault(); 
                    const currentPos = getXY(e);
                    const deltaX = currentPos.x - dragStartRef.current.x;
                    const deltaY = currentPos.y - dragStartRef.current.y;
                    const newPan = { x: initialPanRef.current.x + deltaX, y: initialPanRef.current.y + deltaY };
                    panRef.current = newPan;
                    setPan(newPan);
                };

                const handleUp = (e) => {
                    if (!e.touches || e.touches.length < 2) pinchStartDistRef.current = null;
                    if (!e.touches || e.touches.length === 0) {
                        isDraggingRef.current = false;
                        setIsDraggingUI(false);
                        dragStartRef.current = null;
                    }
                };

                document.addEventListener('mousemove', handleMove);
                document.addEventListener('mouseup', handleUp);
                document.addEventListener('touchmove', handleMove, { passive: false });
                document.addEventListener('touchend', handleUp);

                return () => {
                    document.removeEventListener('mousemove', handleMove);
                    document.removeEventListener('mouseup', handleUp);
                    document.removeEventListener('touchmove', handleMove);
                    document.removeEventListener('touchmove', handleMove);
                    document.removeEventListener('touchend', handleUp);
                };
            }, [currentView]);

            const handleDown = (e) => {
                if (e.target.closest('button') || e.target.closest('input') || e.target.closest('select') || e.target.closest('textarea') || e.target.closest('.bottom-sheet') || e.target.closest('.list-panel') || e.target.closest('.modal-container')) return;
                if (e.touches && e.touches.length === 2) {
                    isDraggingRef.current = false;
                    setIsDraggingUI(false);
                    pinchStartDistRef.current = getTouchDist(e);
                    pinchStartScaleRef.current = scaleRef.current;
                } else {
                    dragStartRef.current = getXY(e);
                    initialPanRef.current = panRef.current;
                    isDraggingRef.current = true;
                    setIsDraggingUI(true);
                }
            };

            const executeFocus = (nodeId, isSmallFocus = false) => {
                setSearchQuery("");
                setSearchResults([]);
                setIsListOpen(false);
                setSelectedNode(null);
                
                if (isSmallFocus) {
                    setFocusTreeId(null);
                    setSmallFamilyFocusId(nodeId);
                } else {
                    const targetNode = rawNodes.find(n => n.id === nodeId);
                    if(!targetNode) return;
                    
                    if (targetNode.ancestors.length === 0) {
                        setSmallFamilyFocusId(null);
                        setFocusTreeId(targetNode.id);
                    } else {
                        const fatherId = targetNode.ancestors[targetNode.ancestors.length - 1];
                        setSmallFamilyFocusId(null);
                        setFocusTreeId(fatherId);
                    }
                }
                setPendingFocusId(nodeId);
            };

            const activeNodes = useMemo(() => {
                if (smallFamilyFocusId) {
                    const main = rawNodes.find(n => n.id === smallFamilyFocusId);
                    if (!main) return rawNodes;

                    let parent1Id = null;
                    let parent2Id = null;

                    if (main.ancestors.length > 0) {
                        parent1Id = main.ancestors[main.ancestors.length - 1];
                        parent2Id = main.motherId || main.fatherId;
                    }

                    return rawNodes.filter(n => {
                        if (n.id === main.id) return true; // Self
                        if (parent1Id && (n.id === parent1Id || n.id === parent2Id)) return true; // Parents
                        
                        // Is n a spouse of main? (n's ancestor ends in main.id AND depth matches)
                        if (n.ancestors.length > 0 && n.ancestors[n.ancestors.length-1] === main.id && n.depth === main.depth) return true;
                        // Is main a spouse of n?
                        if (main.ancestors.length > 0 && main.ancestors[main.ancestors.length-1] === n.id && main.depth === n.depth) return true;
                        
                        // Children of main
                        if (n.ancestors.length > 0 && n.ancestors[n.ancestors.length-1] === main.id && n.depth === main.depth + 1) return true;
                        if (n.motherId === main.id || n.fatherId === main.id) return true;

                        // If main is a spouse, include their children
                        if (main.ancestors.length > 0) {
                            const mainAsSpouseTarget = main.ancestors[main.ancestors.length-1];
                            if (n.ancestors.length > 0 && n.ancestors[n.ancestors.length-1] === mainAsSpouseTarget && n.depth === main.depth + 1 && (n.motherId === main.id || n.fatherId === main.id)) return true;
                        }

                        return false;
                    });
                }
                if (focusTreeId) {
                    return rawNodes.filter(n => n.id === focusTreeId || n.ancestors.includes(focusTreeId));
                }
                
                if (rawNodes.length > 0) {
