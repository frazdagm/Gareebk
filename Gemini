            // ADD RELATIVE WITH INSTANT OPTIMISTIC UI UPDATE
            const handleAddSubmit = async (e) => {
                e.preventDefault();
                
                if (isSubmitting) return;

                // VERIFY EXTERNAL TREE FIRST
                if (isExternalLink && !isAddingRoot) {
