                        (n.ancestors.length === 0 && rawNodes.some(d => d.ancestors.includes(n.id) && d.id.startsWith('dup_')))
                    ).map(n => n.id);

                    return rawNodes.filter(n => {
                        if (disconnectedRootIds.includes(n.id)) return false;
                        if (n.ancestors.some(ancId => disconnectedRootIds.includes(ancId))) return false;
